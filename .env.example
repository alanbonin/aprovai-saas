# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Banco de dados (Supabase Postgres) ────────────────────────────────────────
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Mercado Pago ──────────────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
# Secret HMAC para verificação de assinaturas de webhook (configurar no painel MP)
MERCADOPAGO_WEBHOOK_SECRET=seu_webhook_secret_aqui

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
# Remetente verificado no Resend (domínio precisa estar configurado)
EMAIL_FROM=Aprovai <noreply@seudominio.com.br>

# ── Cron Jobs ─────────────────────────────────────────────────────────────────
# Secret para proteger o endpoint /api/email/lembrete
# Vercel Cron envia automaticamente: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=um_secret_aleatorio_longo_aqui

# ── Push Notifications (Web Push / VAPID) ────────────────────────────────────
# Gere novas chaves com: node -e "require('web-push').generateVAPIDKeys()" | jq .
# Chave PÚBLICA (exposta ao cliente — prefixo NEXT_PUBLIC_ obrigatório)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<gere_com: node -e "require('web-push').generateVAPIDKeys()" >
# Chave PRIVADA (nunca exposta — apenas no servidor)
VAPID_PRIVATE_KEY=<gere_com: node -e "require('web-push').generateVAPIDKeys()" >
# Identidade VAPID (deve ser mailto: ou URL pública do app)
VAPID_SUBJECT=mailto:contato@aprovai.app

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Upstash Redis (Rate Limiting distribuído) ─────────────────────────────────
# Crie grátis em https://console.upstash.com → Redis → Create Database
# OBRIGATÓRIO em produção para rate limiting funcionar em serverless (Vercel)
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxx...

# ── Sentry (monitoramento de erros em produção) ───────────────────────────────
# Crie em https://sentry.io → New Project → Next.js
# Opcional mas altamente recomendado para produção
SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
