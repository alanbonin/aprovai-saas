{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "alias": ["aprovai360.com.br", "www.aprovai360.com.br"],
  "crons": [
    {
      "path": "/api/email/lembrete",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/expirar-assinaturas",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/email/relatorio-semanal",
      "schedule": "0 0 * * 1"
    },
    {
      "path": "/api/email/reativacao",
      "schedule": "0 14 * * 3"
    },
    {
      "path": "/api/cron/streak",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/email/questao-do-dia",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/streak-guard",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/email/admin-semanal",
      "schedule": "0 10 * * 1"
    },
    {
      "path": "/api/cron/importar-editais",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/email/trial-expirando",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/renovar-planos",
      "schedule": "0 5 * * 1"
    }
  ]
}
