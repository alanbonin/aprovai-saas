# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — bloqueia tudo exceto o template de exemplo
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
# .env.example é permitido (template sem valores reais)

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# symlinks externos (ex: .wiki → Obsidian Vault) — ignorados pelo Tailwind v4 e Turbopack
.wiki
.env*.local
.claude/settings.local.json

# Estado interno de scripts de geração (dados operacionais, não código)
scripts/.gerar-progress.json

# Chaves e certificados que possam ser gerados localmente
*.key
*.p12
*.pfx
*.cer
