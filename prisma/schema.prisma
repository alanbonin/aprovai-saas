generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ─── Planos ────────────────────────────────────────────────
model Plan {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  price           Float
  intervalDays    Int      @default(30)
  aiCreditsPerWeek     Int @default(10)   // msgs de mentor/semana (-1 = ilimitado)
  maxAgents            Int @default(2)    // mentores simultâneos
  maxProfiles          Int @default(1)    // concursos/perfis simultâneos
  maxQuestionsPerWeek  Int @default(10)   // questões/semana (-1 = ilimitado)
  maxFlashcardsPerWeek Int @default(10)   // flashcards/semana (-1 = ilimitado)
  maxSimuladosPerWeek  Int @default(0)    // simulados/semana (0 = bloqueado, -1 = ilimitado)
  maxRedacoesPerWeek   Int @default(0)    // redações/semana (0 = bloqueado, -1 = ilimitado)
  maxCasosPerWeek      Int @default(0)    // casos práticos/semana (0 = bloqueado, -1 = ilimitado)
  maxEditalPerWeek     Int @default(0)    // decodificações de edital/semana (0 = bloqueado, -1 = ilimitado)
  maxPdfPerWeek        Int @default(0)    // documentos PDF/semana (0 = bloqueado, -1 = ilimitado)
  hasGroupStudy        Boolean @default(false) // grupos de estudo ilimitados
  hasLongTermMemory    Boolean @default(false) // memória de longo prazo do mentor
  features        String[] @default([])
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  subscriptions   Subscription[]
}

// ─── Usuários ──────────────────────────────────────────────
model User {
  id              String   @id @default(cuid())
  supabaseId      String   @unique
  name            String
  email           String   @unique
  role            Role     @default(STUDENT)
  avatarUrl       String?
  phone           String?  // celular com DDD, ex: +5511999999999 (para SMS 2FA futuro)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  activeProfileId   String?

  subscription      Subscription?
  progress          Progress[]
  simulados         SimuladoHistory[]
  aiUsage           AiUsage[]
  notes             Note[]
  flashcardSets     FlashcardSet[]
  profiles          StudentProfile[]
  studentSubjects   StudentSubject[]
  userAgents        UserAgent[]
  editalFavoritos   EditalFavorito[]
}

enum Role {
  ADMIN
  STUDENT
}

// ─── Assinaturas ───────────────────────────────────────────
model Subscription {
  id              String             @id @default(cuid())
  userId          String             @unique
  planId          String
  status          SubscriptionStatus @default(ACTIVE)
  startDate       DateTime           @default(now())
  endDate         DateTime
  mpPaymentId     String?
  mpSubscriptionId String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user            User               @relation(fields: [userId], references: [id])
  plan            Plan               @relation(fields: [planId], references: [id])
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

// ─── Agentes / Mentores ────────────────────────────────────
model Agent {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  description     String
  categoria       String?   // ex: "Direito Penal", "Administração"
  area            String?   // ex: "penal", "tributario", "fiscal"
  banca           String?   // ex: "cespe", "fgv", "vunesp"
  systemPrompt    String    @db.Text
  avatar          String?
  color           String    @default("#6366f1")
  active          Boolean   @default(true)
  isPremium       Boolean   @default(false)
  createdAt       DateTime  @default(now())

  aiUsage         AiUsage[]
  userAgents      UserAgent[]
}

// ─── Uso de IA (controle de cotas) ────────────────────────
model AiUsage {
  id              String   @id @default(cuid())
  userId          String
  agentId         String
  weekStart       DateTime // início da semana (domingo)
  count           Int      @default(0)
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
  agent           Agent    @relation(fields: [agentId], references: [id])

  @@unique([userId, agentId, weekStart])
}

// ─── Assuntos / Tópicos dentro de Matérias ─────────────────
// Subject 1→N Topic 1→N Question
model Topic {
  id              String   @id @default(uuid())
  subjectId       String
  name            String
  slug            String
  description     String?
  ordem           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  questions       Question[]
  progress        Progress[]

  @@unique([subjectId, slug])
  @@index([subjectId])
}

// ─── Questões ──────────────────────────────────────────────
model Question {
  id              Int      @id @default(autoincrement())
  subjectId       String
  topicId         String?  // null = questão sem tópico classificado ainda
  banca           String?
  year            Int?
  level           String   @default("medio")
  statement       String   @db.Text
  optionA         String?  @db.Text
  optionB         String?  @db.Text
  optionC         String?  @db.Text
  optionD         String?  @db.Text
  optionE         String?  @db.Text
  answer          String
  explanation     String?  @db.Text
  source          String   @default("ia")
  analysis        String?  @db.Text
  artigo          String?  // artigo/dispositivo legal cobrado (ex: "Art. 5º, CF/88")
  dicaBanca       String?  // dica específica sobre como a banca cobra esse conteúdo
  aprovado        Boolean  @default(true)
  createdAt       DateTime @default(now())

  topic           Topic?   @relation(fields: [topicId], references: [id])
  progress        Progress[]
}

// ─── Progresso por questão ─────────────────────────────────
model Progress {
  id              String   @id @default(cuid())
  userId          String
  profileId       String?  // null = dados legados (aparecem em todos os perfis)
  questionId      Int
  topicId         String?  // denormalizado para facilitar stats por assunto
  correct         Boolean
  reviewedAt      DateTime?
  nextReview      DateTime?
  interval        Int      @default(1)
  easeFactor      Float    @default(2.5)
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
  question        Question @relation(fields: [questionId], references: [id])
  topic           Topic?   @relation(fields: [topicId], references: [id])
  // @@unique gerenciado via índices parciais no DB (ver migration-multiprofile.sql)
}

// ─── Histórico de Simulados ────────────────────────────────
model SimuladoHistory {
  id              Int      @id @default(autoincrement())
  userId          String
  profileId       String?  // null = dados legados
  total           Int
  correct         Int
  timeSecs        Int
  subjectIds      String[]
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
}

// ─── Notas pessoais ────────────────────────────────────────
model Note {
  id              String   @id @default(cuid())
  userId          String
  profileId       String?  // null = nota global (plano semanal, pomodoro, grupos)
  subjectId       String
  content         String   @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
}

// ─── Flashcard Sets ────────────────────────────────────────
model FlashcardSet {
  id              String      @id @default(cuid())
  userId          String
  subjectId       String
  name            String
  cards           Json        @default("[]")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User        @relation(fields: [userId], references: [id])
}

// ─── Materiais de Estudo ───────────────────────────────────
model Material {
  id              String        @id @default(cuid())
  title           String
  description     String?
  type            MaterialType
  subjectId       String?
  banca           String?
  fileUrl         String?
  fileSize        Int?
  isPremium       Boolean       @default(false)
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

enum MaterialType {
  PDF
  VIDEO
  LINK
  TEXTO
  APOSTILA
}

// ─── Matérias / Disciplinas ─────────────────────────────────
model Subject {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String?
  categoria       String?
  ordem           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Perfil de Estudo do Aluno ──────────────────────────────
// Um usuário pode ter N perfis (ex: Auditor + Policia Federal)
model StudentProfile {
  id              String   @id @default(cuid())
  userId          String   // sem @unique — agora é 1:N
  label           String?  // nome do perfil, ex: "Auditor SEFAZ-BA"
  isDefault       Boolean  @default(false)
  cargo           String?
  orgao           String?
  dataProva       String?
  dificuldades    String?
  nomePreferido   String?  // como o aluno quer ser chamado (pode ser apelido)
  horasEstudo     Int?     // horas disponíveis por dia para estudar
  nivelAtual      String?  // iniciante | intermediario | avancado
  disponibilidade String?  // manha | tarde | noite | variado
  modalidade      String   @default("CONCURSO_PUBLICO") // CONCURSO_PUBLICO | ENEM | VESTIBULAR | OAB | REVALIDA | CFC
  vestibular      String?  // FUVEST | UNICAMP | UNESP | UERJ (vestibular only)
  trilha          String?  // Medicina | Direito | Engenharia (vestibular / general)
  oabFase         String?  // primeira | segunda (OAB only)
  banca           String?  // banca explícita
  onboardingDone  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
}

// ─── Matérias Escolhidas pelo Aluno ─────────────────────────
model StudentSubject {
  id              String   @id @default(cuid())
  userId          String
  profileId       String?  // null = matéria global (legado)
  subjectId       String
  fromEdital      Boolean  @default(false)
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
  // @@unique gerenciado via índices parciais no DB (ver migration-multiprofile.sql)
}

// ─── Radar de Editais ───────────────────────────────────────
model Edital {
  id                  String    @id @default(cuid())
  titulo              String
  orgao               String
  cargo               String
  area                String?   // "administrativa","ti","juridico","saude","policial","fiscal","educacao"
  vagas               Int?
  salario             Float?
  salarioMax          Float?
  banca               String?
  estado              String?   // "Federal","SP","BA","MG"...
  nivel               String    @default("federal") // "federal","estadual","municipal"
  escolaridade        String?   // "fundamental","medio","superior","pos"
  status              String    @default("previsto") // "previsto","aberto","encerrado","suspenso","resultado"
  descricao           String?   @db.Text
  dataPublicacao      DateTime?
  dataInscricaoInicio DateTime?
  dataInscricaoFim    DateTime?
  dataProva           DateTime?
  link                String?
  editalUrl           String?
  source              String    @default("manual") // "manual","querido_diario"
  sourceRef           String?
  isPremium           Boolean   @default(false)
  active              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  favoritos           EditalFavorito[]
}

model EditalFavorito {
  id        String   @id @default(cuid())
  userId    String
  editalId  String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  edital    Edital   @relation(fields: [editalId], references: [id])

  @@unique([userId, editalId])
}

// ─── Agentes selecionados pelo Aluno ────────────────────────
model UserAgent {
  id              String   @id @default(cuid())
  userId          String
  agentId         String
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
  agent           Agent    @relation(fields: [agentId], references: [id])

  @@unique([userId, agentId])
}
